{{ if eq .chezmoi.os "darwin" -}}
#!/bin/sh

export PATH=/opt/homebrew/bin:$PATH

# Install modern bash (macOS ships bash 3.2)
brew install bash bash-completion@2

# Add Homebrew bash to allowed shells and set as default
BASH_PATH="$(brew --prefix)/bin/bash"
grep -qxF "$BASH_PATH" /etc/shells || echo "$BASH_PATH" | sudo tee -a /etc/shells > /dev/null

echo "Current shell: $SHELL"
[ "$SHELL" != "$BASH_PATH" ] && chsh -s "$BASH_PATH"

brew install ripgrep
yes n | brew install fzf

# To install useful key bindings and fuzzy completion:
yes n | $(brew --prefix)/opt/fzf/install

brew tap common-fate/granted
brew install mise
brew install zoxide

mise use -g java
mise use -g node@lts
mise use -g ruby
mise use -g go
mise use -g python
mise use -g uv@latest
mise use -g bun@latest

# Install global playwright cli for claude code skill
npm install -g @playwright/cli@latest

#!/bin/bash

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.darwin.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF
{{ else if eq .chezmoi.os "linux" -}}

{{ end -}}
